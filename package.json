{
	"name": "obsidian-natural-link",
	"version": "1.0.0-pre-release",
	"description": "Obsidian plugin: create links to notes using natural word forms",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"obsidian-tests": "npm run build && wdio run ./wdio.conf.mjs",
		"demo:capture": "npm run build && wdio run ./wdio.demo.conf.mjs",
		"demo:render": "node ./obsidian-tests/demo/render-demo-gifs.mjs",
		"demo": "npm run demo:capture && npm run demo:render"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.19.10",
		"@wdio/cli": "^9.25.0",
		"@wdio/globals": "^9.23.0",
		"@wdio/local-runner": "^9.25.0",
		"@wdio/mocha-framework": "^9.25.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "^2.6.1",
		"mocha": "^11.7.5",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.56.0",
		"vitest": "^4.0.18",
		"wdio-obsidian-reporter": "^2.3.3",
		"wdio-obsidian-service": "^2.3.3",
		"webdriverio": "^9.25.0"
	},
	"dependencies": {
		"obsidian": "latest",
		"snowball-stemmers": "^0.6.0"
	},
	"overrides": {
		"minimatch": "^10.2.2"
	}
}
