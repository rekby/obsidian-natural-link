{
	"name": "obsidian-natural-link",
	"version": "0.2.0",
	"description": "Obsidian plugin: create links to notes using natural word forms",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"dict:ru:suffix": "tsx scripts/dictionaries/build-russian-suffix-rules.ts",
		"dict:ru:build": "tsx scripts/dictionaries/build-russian-irregular-forms.ts",
		"dict:en:build": "tsx scripts/dictionaries/build-english-irregular-forms.ts",
		"dict:build": "npm run dict:ru:suffix && npm run dict:ru:build && npm run dict:en:build",
		"obsidian-tests": "npm run build && ./node_modules/.bin/wdio run ./wdio.conf.mjs",
		"demo:screenshots": "npm run build && ./node_modules/.bin/wdio run ./wdio.demo.conf.mjs --spec ./obsidian-tests/demo/readme-screenshots.e2e.mjs",
		"demo:capture": "npm run build && ./node_modules/.bin/wdio run ./wdio.demo.conf.mjs",
		"demo:render": "node ./obsidian-tests/demo/render-demo-gifs.mjs",
		"demo": "npm run demo:screenshots && npm run demo:capture && npm run demo:render"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.19.10",
		"@types/tar-stream": "^3.1.4",
		"@wdio/cli": "^9.26.1",
		"@wdio/globals": "^9.26.1",
		"@wdio/local-runner": "^9.26.1",
		"@wdio/mocha-framework": "^9.26.1",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "14.0.0",
		"jiti": "^2.6.1",
		"saxes": "^6.0.0",
		"tar-stream": "^3.1.8",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.3",
		"unbzip2-stream": "^1.4.3",
		"vitest": "^4.0.18",
		"wdio-obsidian-reporter": "^2.3.3",
		"wdio-obsidian-service": "^2.3.3",
		"webdriverio": "^9.26.1"
	},
	"dependencies": {
		"obsidian": "latest",
		"snowball-stemmers": "^0.6.0"
	},
	"overrides": {
		"minimatch": "^10.2.2",
		"serialize-javascript": "^7.0.3"
	}
}
